#!name=Spotify Premium
#!desc=部分解锁premium,音质不能设置为超高(建议登录后再打开脚本,重启app等待脚本生效)。功能: 去除播放广告、歌手/专辑列表正常展示、去除随机播放
#!author=daozen
#!homepage=https://github.com/daozen/rules
#!icon=https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/Spotify.png
#!date=2025-06-27
#############################################
# 优化: 3个JS脚本 → 仅保留1个(protobuf必须用JS)
# header删除 → 原生 header-del
# URL改写 → 原生 header (URL rewrite)

[Rewrite]
# 删除If-None-Match请求头 - 零JS开销
^https:\/\/(?:\w+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/user-customization-service\/v1\/customize$ header-del If-None-Match

# platform=iphone改为ipad + 去掉:443 - 原生URL重写替代spotify-json.js
^https:\/\/((?:\w+-spclient|spclient\.wg)\.spotify\.com)(?::443)?\/((?:artistview\/v1\/artist|album-entity-view\/v2\/album)\/.*)platform=iphone(.*) header https://$1/$2platform=ipad$3

[Script]
# Protobuf解码+注入Premium属性 - 二进制protobuf无法用jq/原生rewrite处理，必须JS
http-response ^https:\/\/(?:\w+-spclient|spclient\.wg)\.spotify\.com(?::443)?\/(?:bootstrap\/v1\/bootstrap|user-customization-service\/v1\/customize)$ script-path=https://raw.githubusercontent.com/daozen/rules/master/js/spotify-proto.js, requires-body=true, binary-body-mode=true, timeout=10, tag=Spotify Proto

[MITM]
hostname = *-spclient.spotify.com, spclient.wg.spotify.com
